{% comment %} Usage: {% render 'trust-strip', line: line %} — warranty years vary only by mattress line. {% endcomment %}
{% case line %}
  {% when 'sova' %}{% assign warranty_years = 15 %}
  {% when 'resto' %}{% assign warranty_years = 10 %}
  {% when 'luma' %}{% assign warranty_years = 7 %}
  {% when 'ultima' %}{% assign warranty_years = 25 %}
  {% when 'riva' %}{% assign warranty_years = 30 %}
  {% else %}{% assign warranty_years = 15 %}
{% endcase %}
<div class="trust-strip">
    <div class="wrap trust-strip-inner">
        <div class="trust-stat reveal" style="transition-delay:0ms;">
            <svg viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l7 4v6c0 5-3.5 8.5-7 10-3.5-1.5-7-5-7-10V6z"/><path d="M9 12l2 2 4-4"/></svg>
            <div><strong>{{ warranty_years }}-Year Warranty</strong><span>On every {{ line | capitalize }}*</span></div>
        </div>
        <div class="trust-stat reveal" style="transition-delay:80ms;">
            <svg viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-3-6.7"/><path d="M21 3v6h-6"/></svg>
            <div><strong>5-Year Full Replacement</strong><span>Total peace of mind*</span></div>
        </div>
        <div class="trust-stat reveal" style="transition-delay:160ms;">
            <svg viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="6" width="14" height="11" rx="2"/><path d="M15 10h4l3 3v4h-7z"/><circle cx="6" cy="19" r="1.6"/><circle cx="18" cy="19" r="1.6"/></svg>
            <div><strong>Free Delivery</strong><span>No hidden fees</span></div>
        </div>
        <div class="trust-stat reveal" style="transition-delay:240ms;">
            <svg viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21V8l9-5 9 5v13"/><path d="M9 21v-8h6v8"/></svg>
            <div><strong>Try In Store</strong><span>Feel it in person</span></div>
        </div>
    </div>
</div>
