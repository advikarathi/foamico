<section class="section" id="contact">
    <div class="wrap">
        <div class="section-shell section-shell--paper">
            <div class="section-head reveal">
                <h2>{{ page.title | default: 'Contact Us' }}</h2>
                <p>We'd love to hear from you.</p>
            </div>
            <div class="contact-grid">
                <div class="contact-card surface-card reveal" style="transition-delay:0ms;">
                    <h3>Foamico Experience Center</h3>
                    <div class="contact-row">
                        <span class="contact-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21c-4-4-8-7.5-8-12a8 8 0 0 1 16 0c0 4.5-4 8-8 12z"></path><circle cx="12" cy="9" r="2.4"></circle></svg>
                        </span>
                        <p>9/3 A, Club Drive Road, Ghitorni, New Delhi, Delhi – 110030</p>
                    </div>
                    <div class="contact-row">
                        <span class="contact-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.1-8.6A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .3 2 .6 2.9a2 2 0 0 1-.5 2.1L8 9.9a16 16 0 0 0 6 6l1.2-1.2a2 2 0 0 1 2.1-.5c.9.3 1.9.5 2.9.6a2 2 0 0 1 1.8 2z"></path></svg>
                        </span>
                        <p><a href="tel:+917496982886">+91 74969 82886</a></p>
                    </div>
                    <div class="contact-row">
                        <span class="contact-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3.5 2"></path></svg>
                        </span>
                        <p>Mon – Sat: 9:00 AM – 6:00 PM</p>
                    </div>
                    <div class="contact-divider"></div>
                    <div class="contact-cta">
                        <strong>Let's Talk</strong>
                        <span>Your perfect sleep is just one call away.</span>
                    </div>
                    <div class="contact-actions">
                        <a class="chat-wa-btn" href="https://wa.me/{{ settings.whatsapp_number }}?text=Hi%20Foamico%2C%20I%27d%20like%20to%20know%20more" target="_blank" rel="noopener">
                            <svg viewBox="0 0 24 24"><path d="M17.6 6.32A7.85 7.85 0 0 0 12.05 4a7.94 7.94 0 0 0-6.87 11.88L4 20l4.24-1.11a7.9 7.9 0 0 0 3.8.97h.01a7.94 7.94 0 0 0 5.55-13.54zm-5.55 12.2a6.6 6.6 0 0 1-3.36-.92l-.24-.14-2.51.66.67-2.45-.16-.25a6.58 6.58 0 0 1 10.24-8.16 6.53 6.53 0 0 1 1.94 4.66 6.6 6.6 0 0 1-6.58 6.6z"></path></svg>
                            WhatsApp
                        </a>
                        <a class="pill-btn pill-btn--outline" style="padding:10px 22px;font-size:13px;" href="tel:+917496982886">
                            <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.1-8.6A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .3 2 .6 2.9a2 2 0 0 1-.5 2.1L8 9.9a16 16 0 0 0 6 6l1.2-1.2a2 2 0 0 1 2.1-.5c.9.3 1.9.5 2.9.6a2 2 0 0 1 1.8 2z"></path></svg>
                            Call Now
                        </a>
                    </div>
                </div>
                <div class="contact-map reveal" style="transition-delay:120ms;">
                    <iframe src="https://www.google.com/maps/embed?origin=mfe&amp;pb=!1m13!1m8!1m3!1d14026.531206225845!2d77.1458!3d28.4906!3m2!1i1024!2i768!4f13.1!2m1!1s28.4906,77.1458!5e0!6i15!3m1!1sen-GB!5m1!1sen-GB" title="Foamico Experience Center location" loading="lazy" referrerpolicy="no-referrer-when-downgrade" allowfullscreen></iframe>
                </div>
            </div>
        </div>
    </div>
</section>

{% schema %}
{ "name": "Contact page", "settings": [] }
{% endschema %}
