<div class="site-header-group">
    <div class="utility-bar">
        <div class="wrap utility-bar-inner">
            <a href="https://forms.gle/W8YhEEdXztsEvcc27" data-form-modal-trigger data-form-title="Become a Dealer" target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21c-4-4-8-7.5-8-12a8 8 0 0 1 16 0c0 4.5-4 8-8 12z"></path><circle cx="12" cy="9" r="2.4"></circle></svg>Become a Dealer
            </a>
            <a href="https://docs.google.com/forms/d/e/1FAIpQLSf7g2S7_WlR-jXpZwQb3qthr8Z7egYZ3m3jYJJYXVN-C0V94w/viewform?embedded=true" data-form-modal-trigger data-form-title="Careers" target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.1-8.6A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .3 2 .6 2.9a2 2 0 0 1-.5 2.1L8 9.9a16 16 0 0 0 6 6l1.2-1.2a2 2 0 0 1 2.1-.5c.9.3 1.9.5 2.9.6a2 2 0 0 1 1.8 2z"></path></svg>Careers
            </a>
        </div>
    </div>

    <header>
        <div class="wrap header-row">
            <a class="brand" href="{{ routes.root_url }}">
                {% if settings.logo %}
                    {{ settings.logo | image_url: width: 240 | image_tag: width: 240, height: 240, alt: shop.name }}
                {% else %}
                    <img src="{{ 'logo.jpeg' | asset_url }}" width="240" height="240" alt="{{ shop.name }}">
                {% endif %}
            </a>
            <ul class="header-nav" id="primary-nav" data-header-nav>
                <li><a href="{{ routes.root_url }}">Home</a></li>
                <li><a href="{{ pages.about.url | default: '/pages/about' }}">About Us</a></li>
                <li class="has-drop" data-has-drop>
                    <a href="{{ pages.mattresses.url | default: '/pages/mattresses' }}">Products</a>
                    <div class="header-drop">
                        <div class="header-drop-col">
                            <a class="header-drop-title" href="{{ pages.mattresses.url | default: '/pages/mattresses' }}">Mattress</a>
                            <a href="/products/sova-luxury-mattress">Sova</a>
                            <a href="/products/resto-classic-mattress">Resto</a>
                            <a href="/products/luma-classic-mattress">Luma</a>
                            <a href="/products/ultima-luxury-mattress">Ultima</a>
                            <a href="/products/riva-1000-mattress">Riva</a>
                        </div>
                        <div class="header-drop-col">
                            <span class="header-drop-title">Pillows</span>
                            <a href="/collections/pillows">Pillows</a>
                        </div>
                        <div class="header-drop-col">
                            <span class="header-drop-title">Accessories</span>
                            <a href="/products/sofa-cum-bed">Sofa Cum Bed</a>
                        </div>
                    </div>
                </li>
                <li><a href="{{ blog.url | default: '/blogs/the-sleepy-times' }}">The Sleepy Times</a></li>
                <li><a href="{{ pages.contact.url | default: '/pages/contact' }}">Contact Us</a></li>
            </ul>
            <button class="nav-toggle" type="button" data-nav-toggle aria-label="Open menu" aria-expanded="false" aria-controls="primary-nav">
                <svg class="nav-toggle-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="7" x2="20" y2="7"></line><line x1="4" y1="12" x2="20" y2="12"></line><line x1="4" y1="17" x2="20" y2="17"></line></svg>
                <svg class="nav-toggle-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="5" x2="19" y2="19"></line><line x1="19" y1="5" x2="5" y2="19"></line></svg>
            </button>
            <a class="pill-btn" style="padding:12px 26px;font-size:14px;" href="{{ routes.root_url }}#stores">Find a Store</a>
        </div>
    </header>
</div>

{% schema %}
{
  "name": "Header",
  "settings": []
}
{% endschema %}
