<section class="scroll-hero" data-scroll-hero aria-label="Foamico sleep film">
    <div class="hero-stage" data-hero-stage>
        <video class="hero-video is-live" data-hero-video-a data-hero-src="{{ 'home-hero.mp4' | asset_url }}" src="{{ 'home-hero.mp4' | asset_url }}" muted autoplay playsinline preload="auto" aria-hidden="true"></video>
        <video class="hero-video" data-hero-video-b muted playsinline preload="none" aria-hidden="true"></video>
        <div class="hero-overlay"></div>
        <div class="hero-copy">
            <div class="wrap">
                <div class="hero-copy-inner">
                    <div class="hero-text">
                        <h1>Sleep, <span class="kiwi-word">engineered</span>.</h1>
                        <p>{{ section.settings.subheading }}</p>
                        <div class="hero-actions">
                            <a class="pill-btn" href="{{ section.settings.primary_cta_url | default: '#products' }}">{{ section.settings.primary_cta_label }}</a>
                            <a class="pill-btn pill-btn--ghost" href="{{ section.settings.secondary_cta_url | default: '#stores' }}">{{ section.settings.secondary_cta_label }}</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

{% schema %}
{
  "name": "Hero video",
  "settings": [
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "German-engineered mattresses, crafted for Indian homes." },
    { "type": "text", "id": "primary_cta_label", "label": "Primary button label", "default": "Explore Mattresses" },
    { "type": "url", "id": "primary_cta_url", "label": "Primary button link" },
    { "type": "text", "id": "secondary_cta_label", "label": "Secondary button label", "default": "Find a Store" },
    { "type": "url", "id": "secondary_cta_url", "label": "Secondary button link" }
  ]
}
{% endschema %}
