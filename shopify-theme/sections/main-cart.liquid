<section class="section">
    <div class="wrap">
        <div class="section-head">
            <h1>{{ 'cart.general.title' | t }}</h1>
        </div>

        {% if cart.item_count == 0 %}
            <p style="text-align:center;">Your cart is empty.</p>
            <p style="text-align:center;"><a class="pill-btn" href="{{ routes.root_url }}">Continue Shopping</a></p>
        {% else %}
            <form action="{{ routes.cart_url }}" method="post" novalidate>
                <div class="table-scroll">
                    <table>
                        <thead>
                            <tr><th>Product</th><th>Price</th><th>Quantity</th><th>Total</th></tr>
                        </thead>
                        <tbody>
                            {% for item in cart.items %}
                                <tr>
                                    <td>
                                        <a href="{{ item.url }}" style="display:flex;align-items:center;gap:12px;">
                                            {% if item.image %}{{ item.image | image_url: width: 100 | image_tag: width: 80, loading: 'lazy', alt: item.title }}{% endif %}
                                            <span>{{ item.product.title }}{% if item.variant.title != 'Default Title' %}<br><small>{{ item.variant.title }}</small>{% endif %}</span>
                                        </a>
                                    </td>
                                    <td>{{ item.original_price | money }}</td>
                                    <td><input type="number" name="updates[]" value="{{ item.quantity }}" min="0" style="width:64px;padding:6px;"></td>
                                    <td>{{ item.final_line_price | money }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                <div style="display:flex;justify-content:flex-end;align-items:center;gap:20px;margin-top:24px;">
                    <button type="submit" name="update" class="pill-btn pill-btn--ghost">Update Cart</button>
                    <span class="price" style="font-size:1.4rem;">Subtotal: {{ cart.total_price | money }}</span>
                </div>
                <div style="text-align:right;margin-top:16px;">
                    <button type="submit" name="checkout" class="pill-btn">Checkout</button>
                </div>
            </form>
        {% endif %}
    </div>
</section>

{% schema %}
{ "name": "Cart", "settings": [] }
{% endschema %}
