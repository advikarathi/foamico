{% comment %}
  "Shop all mattresses" page (products.html equivalent) — one card per mattress line,
  linking to that line's default tier product, with lowest price across the line's 3
  tiers pulled from the manually-created per-line collections (see tier-tabs.liquid /
  the theme handoff notes for how those collections are set up).
{% endcomment %}
{% liquid
  assign lines = 'sova,resto,luma,ultima,riva' | split: ','
  assign default_products = 'sova-luxury-mattress,resto-classic-mattress,luma-classic-mattress,ultima-luxury-mattress,riva-1000-mattress' | split: ','
  assign taglines = 'Back Sleepers|Everyday Comfort,Balanced Comfort|Daily Recovery,Side Sleepers|Cooler Sleep,Back Pain Relief|Firm Support,Premium Support|Plush Comfort' | split: ','
%}
<section class="section" style="padding-bottom:56px;">
    <div class="wrap">
        <div class="section-head reveal">
            <h2>{{ page.title | default: 'Every Foamico Mattress' }}</h2>
            <p>Five ranges, five different feels — choose the one that matches how you sleep.</p>
        </div>
        <div class="sort-bar reveal">
            <div class="sort-select-wrap">
                <select class="sort-select" id="mattressSort" aria-label="Sort mattresses">
                    <option value="default">Sort: Featured</option>
                    <option value="price-asc">Price: Low to High</option>
                    <option value="price-desc">Price: High to Low</option>
                    <option value="new">Newest First</option>
                </select>
            </div>
        </div>
        <div class="product-grid" id="mattressGrid">
            {% for line in lines %}
                {% assign i = forloop.index0 %}
                {% assign default_product = all_products[default_products[i]] %}
                {% assign tier_collection = collections[line] %}
                {% assign min_price = default_product.price_min %}
                {% if tier_collection %}
                    {% for sibling in tier_collection.products %}
                        {% if sibling.price_min < min_price %}{% assign min_price = sibling.price_min %}{% endif %}
                    {% endfor %}
                {% endif %}
                <a class="product-card reveal" href="{{ default_product.url }}" style="transition-delay:{{ forloop.index0 | times: 80 }}ms;" data-price="{{ min_price }}" data-launched="{{ default_product.created_at | date: '%s' }}">
                    <div class="product-media">
                        <video class="product-video" data-src="{{ 'product-' | append: line | append: '-video.mp4' | asset_url }}" poster="{{ 'lifestyle-' | append: line | append: '.jpg' | asset_url }}" preload="none" muted loop playsinline aria-label="{{ line | capitalize }} mattress, rotating view"></video>
                        <span class="media-badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-3-6.7"></path><path d="M21 3v5h-5"></path></svg>3D View</span>
                    </div>
                    <div class="product-body">
                        <h3 class="product-name">{{ line | capitalize }}</h3>
                        <div class="product-tags"><span>{{ taglines[i] | split: '|' | first }}</span><span>{{ taglines[i] | split: '|' | last }}</span></div>
                        <div class="product-price-row"><span class="product-price">From {{ min_price | money }}</span></div>
                        <span class="product-link">Learn more →</span>
                    </div>
                </a>
            {% endfor %}
        </div>
    </div>
</section>

{% schema %}
{ "name": "Shop all mattresses", "settings": [] }
{% endschema %}
