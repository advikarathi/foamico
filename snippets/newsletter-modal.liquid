<div class="newsletter-overlay" data-newsletter-overlay>
    <div class="newsletter-modal" role="dialog" aria-modal="true" aria-label="Subscribe to our newsletter">
        <button class="newsletter-close" type="button" data-newsletter-close aria-label="Close">&times;</button>
        <div class="newsletter-body" data-newsletter-body>
            <h3>Subscribe to our newsletter</h3>
            <p>Sleep tips, new ranges, and offers — straight to your inbox.</p>
            <form data-newsletter-form>
                <input type="email" name="email" placeholder="Your email" aria-label="Email address" required>
                <input type="tel" name="phone" placeholder="Your phone number" aria-label="Phone number" pattern="[0-9+ -]{7,15}" required>
                <input type="hidden" name="_subject" value="Foamico Newsletter Signup">
                <input type="hidden" name="_captcha" value="false">
                <button type="submit">Subscribe</button>
            </form>
            <p class="newsletter-error" data-newsletter-error hidden>Something went wrong — please try again in a moment.</p>
        </div>
    </div>
</div>
