                        <path d="M30 332 L490 332 L490 356 Q490 380 450 380 L70 380 Q30 380 30 356 Z" fill="#F6F8F1" stroke="#95C12B" stroke-width="2"/>
                        <path d="M60 358 l16 -10 l16 10 l16 -10 l16 10 l16 -10 l16 10 l16 -10 l16 10 l16 -10 l16 10 l16 -10 l16 10 l16 -10 l16 10 l16 -10 l16 10 l16 -10 l16 10 l16 -10 l16 10 l16 -10 l16 10 l16 -10 l16 10" stroke="#95C12B" stroke-width="1.1" fill="none" opacity=".6"/>
