                        <rect x="30" y="106" width="460" height="50" fill="#F6F8F1" stroke="#9D9E9E" stroke-width="2"/>
                        <g stroke="#6B6B6B" stroke-width="1.4" fill="none" opacity=".6">
                            <circle cx="80" cy="131" r="9"/><circle cx="150" cy="131" r="9"/><circle cx="220" cy="131" r="9"/><circle cx="290" cy="131" r="9"/><circle cx="360" cy="131" r="9"/><circle cx="430" cy="131" r="9"/>
                        </g>
                        <text x="12" y="137">C</text>
                    </g>
                    <g id="slabD" class="slab" data-layer="D">
                        <rect x="30" y="160" width="460" height="168" fill="#3F5E12" stroke="#1A1A1A" stroke-width="2"/>
