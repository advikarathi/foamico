{% comment %} Bespoke content for the Sova Classic Mattress product — layer diagram, comfort
   scale, feature cards, comparison table, testimonial, size guide, FAQ. Ported verbatim
   from sova-classic.html. Rendered by sections/main-product.liquid via two parts: 'spec' (inside
   the buy panel) and 'body' (the "Inside the Sova" section onward). {% endcomment %}

{% case part %}

{% when 'spec' %}
    <div class="spec-mini">
        <div><b>Thickness</b>6"</div>
        <div><b>Comfort Scale</b>Firm</div>
        <div><b>Best for</b>Back &amp; combination sleepers</div>
    </div>

{% when 'body' %}
    <section class="story section--dark">
        <blockquote>Obsessed with mattresses, <em>so you can be obsessed with sleep.</em></blockquote>
        <p>Every Sova Classic fuses traditional craftsmanship with dependable foam technology — certified foams, precision quilting, and a layer stack we've refined year after year, backed by a 15-year warranty.</p>
    </section>

    <section class="section" id="inside">
        <div class="wrap">
            <div class="section-head reveal" style="margin-bottom:0;text-align:left;max-width:620px;margin-left:0;">
                <h2>Five layers of engineered comfort</h2>
                <p>Tap a layer to see what it does. Sova Classic keeps the comfort stack simple — Plush Core Latex foam above the same trusted Posture Bond orthopedic core used across the whole Sova range.</p>
            </div>

            <div class="layers-grid">
                <svg class="layer-svg" viewBox="0 0 520 424" role="img" aria-label="Cross-section of the Sova Classic mattress showing five layers">
                    <g id="slabA" class="slab" data-layer="A">
                        <path d="M30 44 Q30 22 66 22 L454 22 Q490 22 490 44 L490 58 L30 58 Z" fill="#F6F8F1" stroke="#95C12B" stroke-width="2"/>
