<section class="section">
    <div class="wrap">
        <div class="section-head">
            <h1>All Collections</h1>
        </div>
        <div class="product-grid">
            {% for collection in collections %}
                <a class="product-card" href="{{ collection.url }}">
                    <div class="product-media">
                        {% if collection.featured_image %}{{ collection.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: collection.title }}{% endif %}
                    </div>
                    <div class="product-body">
                        <h3 class="product-name">{{ collection.title }}</h3>
                    </div>
                </a>
            {% endfor %}
        </div>
    </div>
</section>

{% schema %}
{ "name": "List collections", "settings": [] }
{% endschema %}
