<section class="section">
    <div class="wrap">
        <div class="section-head">
            <h1>Search</h1>
        </div>
        <form action="{{ routes.search_url }}" method="get" role="search" style="max-width:480px;margin:0 auto 40px;display:flex;gap:8px;">
            <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search products" style="flex:1;padding:12px 16px;border:1px solid var(--ms-line);border-radius:var(--ms-radius-pill);">
            <button class="pill-btn" type="submit">{{ 'general.search.search' | t }}</button>
        </form>

        {% if search.performed %}
            {% if search.results.size == 0 %}
                <p style="text-align:center;">No results found for "{{ search.terms }}".</p>
            {% else %}
                <div class="product-grid">
                    {% for item in search.results %}
                        <a class="product-card" href="{{ item.url }}">
                            <div class="product-media">
                                {% if item.featured_media %}{{ item.featured_media | image_url: width: 600 | image_tag: loading: 'lazy', alt: item.title }}{% endif %}
                            </div>
                            <div class="product-body">
                                <h3 class="product-name">{{ item.title }}</h3>
                            </div>
                        </a>
                    {% endfor %}
                </div>
            {% endif %}
        {% endif %}
    </div>
</section>

{% schema %}
{ "name": "Search", "settings": [] }
{% endschema %}
