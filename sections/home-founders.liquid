<section class="section">
    <div class="wrap">
        <div class="section-shell section-shell--paper">
            <div class="founder-top reveal">
                <h2 class="founder-heading">Meet the Founders</h2>
                <div class="founder-photo-sm" aria-hidden="true"><strong>40</strong>years of mattress experience</div>
            </div>
            <div class="founder-cards reveal" style="transition-delay:60ms;">
                <div class="founder-card">
                    <div class="founder-card-photo">
                        <img src="{{ 'founder-rahul-mukim.jpg' | asset_url }}" alt="Rahul Mukim, Co-Founder &amp; CEO of Foamico" width="1176" height="1060" loading="lazy">
                    </div>
                    <div class="founder-card-name">Rahul <span>Mukim</span></div>
                    <div class="founder-card-role">Co-Founder &amp; CEO</div>
                    <div class="founder-card-tags">
                        <span>Operations</span><span class="dot" aria-hidden="true"></span><span>People</span><span class="dot" aria-hidden="true"></span><span>Technology</span>
                    </div>
                </div>
                <div class="founder-card">
                    <div class="founder-card-photo">
                        <img src="{{ 'founder-kunal-mukim.jpg' | asset_url }}" alt="Kunal Mukim, Co-Founder &amp; Director of Foamico" width="1142" height="1070" loading="lazy">
                    </div>
                    <div class="founder-card-name">Kunal <span>Mukim</span></div>
                    <div class="founder-card-role">Co-Founder &amp; Director</div>
                    <div class="founder-card-tags">
                        <span>Sales</span><span class="dot" aria-hidden="true"></span><span>Distribution</span><span class="dot" aria-hidden="true"></span><span>Finance</span>
                    </div>
                </div>
            </div>
            <div class="founder-quote-banner reveal" style="transition-delay:100ms;">
                <span class="founder-quote-mark" aria-hidden="true">&ldquo;</span>
                <p class="founder-quote-text">One Vision. Two Minds. <span class="kiwi-word">Endless Comfort.</span></p>
                <div class="founder-attribution">Rahul Mukim &amp; Kunal Mukim <span>|</span> The Founders</div>
            </div>
        </div>
    </div>
</section>

{% schema %}
{ "name": "Founders", "settings": [] }
{% endschema %}
