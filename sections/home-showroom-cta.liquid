<section class="section" id="stores">
    <div class="wrap">
        <div class="section-head reveal">
            <h2>Find a Showroom Near You</h2>
            <p>Talk to a sleep expert, compare mattress feels, and choose the Foamico range that fits your body and budget.</p>
        </div>
        <div class="showroom-cta surface-card reveal">
            <div>
                <h3>300+ stores across 15 cities</h3>
                <p>Visit in person to compare feels before you decide.</p>
            </div>
            <a class="pill-btn" style="padding:12px 26px;font-size:14px;" href="{{ pages.contact.url | default: '/pages/contact' }}">Find a Store</a>
        </div>
        <div class="city-tags reveal" aria-label="Cities with Foamico showrooms">
            <span>Mumbai</span><span>Hyderabad</span><span>Chennai</span><span>Pune</span><span>Ahmedabad</span><span>Kolkata</span><span>Jaipur</span><span>Lucknow</span><span>Chandigarh</span><span>Indore</span>
        </div>
    </div>
</section>

{% schema %}
{ "name": "Showroom CTA", "settings": [] }
{% endschema %}
